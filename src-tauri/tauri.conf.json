{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "uode",
  "version": "0.1.0",
  "identifier": "com.user.uode",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../apps/web/out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "uode",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ5Qzg2N0RDQjFBM0NEQUEKUldTcXphT3gzR2ZJMlh4MWxsNVRlbklsYnJ5SWhrcEw5eTBRZ2JuY2JTeEtUMjVmRFNWaDA5OFkK",
      "endpoints": [
        "https://github.com/WOOU-0510/uode/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
