    "classnames": "^2.5.1"
  },
  "devDependencies": {
    "@svgr/core": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@biomejs/biome": "2.3.11",
    "@tsdown/css": "^0.21.6",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lightningcss": "^1.32.0",
    "sass": "^1.98.0",
    "tsdown": "^0.21.6",
    "typescript": "^6.0.2"
  }
}
