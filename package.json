{
  "name": "uode",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/base-ui/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "bun x turbo run build",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format --write",
    "format:fix": "biome format --write --fix",
    "tauri": "tauri",
    "ic:g": "turbo run ic:g --filter=web",
    "t:g": "turbo run t:g --filter=web"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@tauri-apps/cli": "^2",
    "turbo": "^2.4.4"
  }
}
